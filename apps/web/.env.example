# =============================================================================
# BabyPeek Web Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values

# =============================================================================
# API Configuration
# =============================================================================
# Backend Server URL
VITE_SERVER_URL=http://localhost:3000

# =============================================================================
# PostHog Analytics [OPTIONAL]
# =============================================================================
# Get from PostHog: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=

# Optional: Custom PostHog host (defaults to https://app.posthog.com)
# VITE_POSTHOG_HOST=https://app.posthog.com

# Performance: only "true" or "1" enables autocapture and pageleave
VITE_POSTHOG_AUTOCAPTURE=false
# Performance: only "true" or "1" enables session recording
VITE_POSTHOG_SESSION_RECORDING=false

# =============================================================================
# Sentry Error Tracking [OPTIONAL]
# =============================================================================
# Get from Sentry: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=

# Performance: only "true" or "1" enables tracing
VITE_SENTRY_ENABLE_TRACING=false
# Performance: only "true" or "1" enables session replay
VITE_SENTRY_ENABLE_REPLAY=false

# =============================================================================
# Facebook Pixel [OPTIONAL]
# =============================================================================
# Get from Meta Events Manager: https://business.facebook.com/events_manager
VITE_FACEBOOK_PIXEL_ID=
